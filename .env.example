# Copy to .env.local for local dev. Vercel reads its own values from the project's env vars dashboard.

# Postgres (Neon). Use the pooled connection string from Neon's "Connection string" UI.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Auth.js v5. Generate with: npx auth secret
AUTH_SECRET=replace-me

# OpenAI key used by the AI documentation endpoint.
OPENAI_API_KEY=sk-...

# Marketing site URL (used in transactional links). In prod this is https://audithalo.com.
MARKETING_URL=http://localhost:3000

# App URL (used by NextAuth callbacks). In prod this is https://app.audithalo.com.
APP_URL=http://localhost:3000

# Resend transactional email. If unset, emails are logged to console (local dev only).
RESEND_API_KEY=
EMAIL_FROM="AuditHalo <info@audithalo.com>"
# Resend Audience ID for newsletter subscribers (Audiences → click audience → URL contains ID).
# If unset, newsletter subscribers are still notified via email to info@audithalo.com.
RESEND_AUDIENCE_ID=

# Stripe Billing — use test keys (sk_test_/pk_test_) in non-prod environments.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Created when you register the webhook endpoint in Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=
# Price IDs from the products configured in Stripe.
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_PRACTICE_BASE=
STRIPE_PRICE_PRACTICE_SEAT=

# Sentry — error monitoring (https://sentry.io). If unset, Sentry no-ops.
NEXT_PUBLIC_SENTRY_DSN=
# Optional, for source map upload at build time:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — product analytics (https://posthog.com). If unset, PostHog no-ops.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft (Teams + Outlook Calendar) OAuth — see docs/strategy/08-scheduling-and-calendar.md.
# Created in Entra ID app registration. Redirect URI to register there:
#   {APP_URL}/api/auth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Google (Meet + Calendar) OAuth — same doc.
# Created in Google Cloud Console → APIs & Services → Credentials. Redirect URI:
#   {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paycor OAuth — registered app credentials from AppCreator.
# Redirect URI to register in Paycor: {APP_URL}/api/paycor/callback
PAYCOR_CLIENT_ID=
PAYCOR_CLIENT_SECRET=
# Optional override; defaults to {APP_URL}/api/paycor/callback
# PAYCOR_REDIRECT_URI=

# AES-256-GCM key for encrypting per-user OAuth tokens at rest. Reused for
# both Microsoft and Google tokens (locked decision in docs/strategy/08).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MS_TOKEN_ENCRYPTION_KEY=
